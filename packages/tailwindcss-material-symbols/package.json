{
  "name": "@janispritzkau/tailwindcss-material-symbols",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janispritzkau/tailwindcss-material-symbols.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs",
      "style": "./dist/index.css"
    },
    "./subset": {
      "import": "./dist/subset.js",
      "types": "./dist/subset.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    },
    "./outlined.css": "./assets/material-symbols-outlined.css",
    "./rounded.css": "./assets/material-symbols-rounded.css",
    "./sharp.css": "./assets/material-symbols-sharp.css"
  },
  "files": [
    "assets",
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.17 || ^4.1.13",
    "vite": "^7.1.7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "subset-font": "^2.4.0"
  },
  "devDependencies": {
    "@types/subset-font": "^2.3.0",
    "lightningcss": "^1.30.2",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.7"
  }
}
