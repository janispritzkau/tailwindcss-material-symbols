{
  "name": "@janispritzkau/tailwindcss-material-symbols-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run \"/^(build-only|type-check)$/\"",
    "build-only": "pnpm -r build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write **/src/**",
    "update:codepoints": "tsx ./scripts/update-codepoints.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@types/node": "^24.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tsdown": "^0.15.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
